// Dhanveer — Sales Intelligence OS
// Prisma schema for PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL_SENT
  NEGOTIATION
  WON
  LOST
}

enum LeadSource {
  GOOGLE_PLACES
  WHATSAPP
  MANUAL
  REFERRAL
  WEBSITE
  OTHER
}

enum UserRole {
  ADMIN
  SALES
  VIEWER
}

enum TaskType {
  CALL
  FOLLOW_UP
  MEETING
  EMAIL
  OTHER
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  role         UserRole @default(SALES)
  passwordHash String?
  permissions  String[] @default([])   // feature flags: ai_pitch, whatsapp, manage_leads, delete_leads
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  leads        Lead[]   @relation("AssignedLeads")
  tasks        Task[]   @relation("AssignedTasks")

  @@map("users")
}

model Lead {
  id           String     @id @default(cuid())
  businessName String
  ownerName    String?
  phone        String?
  email        String?
  address      String?
  city         String?
  state        String?
  pincode      String?
  status       LeadStatus @default(NEW)
  source       LeadSource @default(MANUAL)
  notes        String?
  tags         String[] @default([])   // Cafe | QSR Chain | Key Account | Hotels/Bakery/Restaurant | PAN Asian | Dessert Stores | Industrial | Chef/Consultant | Distributors | Export
  googlePlaceId String?   @unique
  researchData  Json?
  researchedAt  DateTime?

  assignedToId String?
  assignedTo   User?      @relation("AssignedLeads", fields: [assignedToId], references: [id])

  activities    LeadActivity[]
  tasks         Task[]
  rasikEvents   RasikEvent[]
  score         LeadScore?
  enrollments   LeadSequenceEnrollment[]

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([status])
  @@index([city])
  @@index([assignedToId])
  @@map("leads")
}

model LeadActivity {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type      String   // "CALL" | "WHATSAPP" | "EMAIL" | "VISIT" | "NOTE"
  note      String?
  createdAt DateTime @default(now())

  @@index([leadId])
  @@map("lead_activities")
}

model Task {
  id          String    @id @default(cuid())
  title       String
  type        TaskType  @default(FOLLOW_UP)
  dueDate     DateTime?
  completed   Boolean   @default(false)
  notes       String?

  leadId      String?
  lead        Lead?     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  assignedToId String?
  assignedTo   User?    @relation("AssignedTasks", fields: [assignedToId], references: [id])

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([leadId])
  @@index([assignedToId])
  @@index([dueDate])
  @@map("tasks")
}

// ─── Product Knowledge Base ───────────────────────────────────────────────────

model ProductCategory {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  sortOrder   Int       @default(0)
  products    Product[]
  createdAt   DateTime  @default(now())

  @@map("product_categories")
}

model Product {
  id              String          @id @default(cuid())
  name            String
  sku             String?         @unique
  categoryId      String
  category        ProductCategory @relation(fields: [categoryId], references: [id])
  description     String?
  targetCustomers String?         // "cafes, restaurants, hotels, QSR"
  usages          String?         // how to use / application areas
  keyBenefits     String?
  hsnCode         String?
  gstRate         Float?          // e.g. 18 for 18%
  mrp             Float?
  dealerPrice     Float?
  moq             String?         // "1 box (25 sachets)"
  packSize        String?         // "25 sachets x 25g"
  shelfLife       String?
  isActive        Boolean         @default(true)
  sortOrder       Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([categoryId])
  @@map("products")
}

// ─── Rasik Integration ────────────────────────────────────────────────────────

model RasikConfig {
  id        String   @id @default(cuid())
  baseUrl   String
  apiKey    String
  enabled   Boolean  @default(true)
  updatedAt DateTime @updatedAt

  @@map("rasik_config")
}

model RasikEvent {
  id          String   @id @default(cuid())
  eventType   String   // "LEAD_QUALIFIED" | "CHAT_ENDED" | "ORDER_PLACED" | "ENQUIRY"
  rasikRef    String?  // Rasik's internal ID for the event
  leadId      String?
  lead        Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  payload     Json
  processed   Boolean  @default(false)
  processedAt DateTime?
  createdAt   DateTime @default(now())

  @@index([leadId])
  @@index([eventType])
  @@map("rasik_events")
}

// ─── Lead Scoring ─────────────────────────────────────────────────────────────

model LeadScore {
  id            String   @id @default(cuid())
  leadId        String   @unique
  lead          Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  score         Int      @default(0)   // 0-100
  tier          String   @default("COLD")  // HOT | WARM | COLD
  fitScore      Int      @default(0)   // product fit
  engageScore   Int      @default(0)   // engagement / activity
  intentScore   Int      @default(0)   // buying intent signals
  reasoning     String?
  lastScoredAt  DateTime @default(now())

  @@map("lead_scores")
}

// ─── Lead Discovery ───────────────────────────────────────────────────────────

model DiscoverySearch {
  id              String    @id @default(cuid())
  label           String
  cities          String[]
  query           String    // e.g. "cafe restaurant bakery bubble tea"
  tagsToApply     String[]  @default([])  // auto-tag imported leads
  isActive        Boolean   @default(true)
  lastRunAt       DateTime?
  lastFoundCount  Int       @default(0)
  totalAdded      Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("discovery_searches")
}

// ─── WhatsApp Sequences ───────────────────────────────────────────────────────

model WhatsAppSequence {
  id          String                   @id @default(cuid())
  name        String
  description String?
  isActive    Boolean                  @default(true)
  steps       WhatsAppSequenceStep[]
  enrollments LeadSequenceEnrollment[]
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  @@map("whatsapp_sequences")
}

model WhatsAppSequenceStep {
  id         String           @id @default(cuid())
  sequenceId String
  sequence   WhatsAppSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  stepNumber Int
  delayDays  Int              // days after enrollment to send (0 = same day)
  message    String           // supports {name} {business} {city} placeholders

  @@index([sequenceId])
  @@map("whatsapp_sequence_steps")
}

model LeadSequenceEnrollment {
  id           String           @id @default(cuid())
  leadId       String
  lead         Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  sequenceId   String
  sequence     WhatsAppSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  currentStep  Int              @default(0)   // index of next step to send
  enrolledAt   DateTime         @default(now())
  nextSendAt   DateTime?
  lastSentAt   DateTime?
  status       String           @default("ACTIVE")  // ACTIVE | PAUSED | COMPLETED | UNSUBSCRIBED

  @@unique([leadId, sequenceId])
  @@index([status, nextSendAt])
  @@map("lead_sequence_enrollments")
}

